## Copy this file to .env.local for real local secrets.
## Local dev loads .env, .env.local, .env.development, and .env.development.local.

NODE_ENV=development
HOST=0.0.0.0
APP_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8787
ALLOWED_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://localhost:5432/lemonsuk
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-before-production
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Example managed avatar storage. Replace with your real AWS bucket + CloudFront domain.
AVATAR_S3_BUCKET=lemonsuk-prod-agent-avatars
AVATAR_S3_REGION=us-east-1
AVATAR_CLOUDFRONT_BASE_URL=https://cdn.lemonsuk.com
AVATAR_S3_PREFIX=agent-avatars
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=
X_OAUTH_AUTHORIZE_URL=https://x.com/i/oauth2/authorize
X_OAUTH_TOKEN_URL=https://api.x.com/2/oauth2/token
X_API_BASE_URL=https://api.x.com/2
PORT=8787
INTERNAL_API_BASE_URL=http://localhost:8787
API_INTERNAL_BASE_URL=http://localhost:8787/api/v1
INTERNAL_SERVICE_TOKEN=change-me-before-production
REVIEW_CONSOLE_ACCESS_KEY=change-me-before-production
REVIEW_QUEUE_KEY=lemonsuk:review-requested
EDDIE_BASE_URL=
EDDIE_API_KEY=
LEMONSUK_REVIEW_TOKEN=
LEMONSUK_REVIEW_WEBHOOK_SECRET=
