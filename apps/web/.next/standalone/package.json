{
  "name": "lemonsuk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c yellow,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run migrate && tsx watch apps/api/src/server.ts",
    "dev:web": "NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL:-http://localhost:8787} next dev apps/web -p 5173",
    "migrate": "tsx scripts/migrate.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run build:api && npm run build:web",
    "build:api": "tsup apps/api/src/server.ts --format esm --platform node --out-dir dist/api --clean",
    "build:web": "next build apps/web",
    "start:api": "node dist/api/server.js",
    "start:web": "next start apps/web -p 3000",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "cheerio": "^1.1.2",
    "chrono-node": "^2.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^14.2.35",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.0",
    "pg-mem": "^3.0.14",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^3.2.4"
  }
}
